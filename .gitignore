**/reviews/
**/.vscode/

# Local Claude Code settings (not shared)
.claude/settings.local.json

# Deploy outputs at repo root — generated by deploy.sh from core/ when
# this repo is used as a deploy target during local testing.
# Source templates live in core/; root-level deploy outputs must never be
# committed. Rules are anchored with a leading slash so they only match
# at the repo root and never shadow tracked source under core/.
# The repo-specific AGENTS.md at the root IS tracked — it documents how
# to maintain this template library and is unrelated to the AGENTS.md
# that deploy.sh writes into target repos.
/.claude/
/.context/
/.cursor/
/.devin/
/.windsurfrules
/.github/copilot-instructions.md
/.github/skills/
/CLAUDE.md

# Engagement artefacts — assessment reports, pen-test write-ups, and review
# outputs produced by running these playbooks against a target codebase.
# Keep them locally under /engagements/ so they cannot be accidentally
# committed back to this template repo.
/engagements/
